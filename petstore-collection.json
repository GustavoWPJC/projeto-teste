						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.environment.set(\"petId\", Math.floor(Math.random() * 900000) + 100000);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json()",
									"",
									"pm.test(\"Status code é 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Pet criado com o nome correto\", function(){",
									"    pm.expect(jsonData.name).to.eql(\"Bellinha\")",
									"})",
									"",
									"pm.test(\"O status do pet é available\", function(){",
									"    pm.expect(jsonData.status).to.eql(\"available\")",
									"})",
									"",
									"pm.test(\"A estrutura do json é válida\", function(){",
									"",
									"    pm.expect(jsonData).to.have.property(\"id\")",
									"    pm.expect(jsonData).to.have.property(\"category\")",
									"    pm.expect(jsonData).to.have.property(\"name\")",
									"    pm.expect(jsonData).to.have.property(\"photoUrls\")",
									"    pm.expect(jsonData).to.have.property(\"tags\")",
									"    pm.expect(jsonData).to.have.property(\"status\")",
									"})",
									"",
									"pm.test(\"O tipo de resposta é object\", function(){",
									"    pm.expect(jsonData).to.be.an('object')",
									"})",
									"",
									"pm.test(\"O tempo de respost é abaixo de 300\", function(){",
									"    pm.expect(pm.response.responseTime).to.be.below(300)",
									"})",
									"",
									"pm.environment.set(\"petId\", jsonData.id)"
								],
